{
  "name": "gradtrack",
  "version": "1.0.0",
  "description": "Graduate tracking and survey management system",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && composer install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && php -S localhost:8000",
    "build:frontend": "cd frontend && npm run build",
    "deploy:backend": "cd backend && eb deploy",
    "deploy:frontend": "cd frontend && amplify publish",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "graduate-tracking",
    "survey",
    "education"
  ],
  "author": "GradTrack Team",
  "license": "UNLICENSED"
}
